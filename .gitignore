# =============================================================================
# Orchestra — .gitignore для VPN инфраструктуры
# =============================================================================

# -----------------------------------------------------------------------------
# СЕКРЕТЫ И КОНФИДЕНЦИАЛЬНЫЕ ДАННЫЕ
# -----------------------------------------------------------------------------
# Файлы с паролями, ключами, токенами
*.key
*.pem
*.crt
*.cert
*.p12
*.pfx
*.secret
*.private
id_rsa
id_dsa
*.gpg
*.asc

# Переменные окружения и конфиги с секретами
.env
.env.*
.env.local
.env.production
.env.development
.secret
.credentials
config.local.*
*.conf.local

# SSH ключи (кроме публичных)
*_rsa
*_dsa
*_ecdsa
*_ed25519
!*.pub

# -----------------------------------------------------------------------------
# СИСТЕМНЫЕ ФАЙЛЫ И ВРЕМЕННЫЕ ФАЙЛЫ
# -----------------------------------------------------------------------------
# Временные файлы
*.tmp
*.temp
*.swp
*.swo
*~
.*.swp
.*.swo
*.pid
*.lock
*.lock.*

# Системные файлы
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# ЛОГИ И ДАННЫЕ ПРИЛОЖЕНИЙ
# -----------------------------------------------------------------------------
# Логи приложений
*.log
logs/
log/
var/log/

# Файлы состояния и данных
.state/
.state/*
*.state
*.db
*.sqlite
*.sqlite3
*.dump
*.backup

# Кэш и временные данные
.cache/
.cache/*
tmp/
temp/
/var/tmp/
/var/cache/

# -----------------------------------------------------------------------------
# ОРКЕСТРАЦИЯ И ДЕПЛОЙ
# -----------------------------------------------------------------------------
# Файлы состояния Orchestra
/opt/orchestra/state/
/opt/orchestra/state/*
/opt/orchestra/fleet/nodes.conf
/opt/orchestra/backups/
/opt/orchestra/backups/*

# Резервные копии
*.bak
*.backup
*.old
*.orig
*.rej
*.7z
*.zip
*.tar.gz
*.tgz
*.rar

# -----------------------------------------------------------------------------
# XRAY И VPN КОМПОНЕНТЫ
# -----------------------------------------------------------------------------
# Конфиги Xray с секретами
/etc/xray/config.json
/etc/xray/users.txt
/etc/xray/reality_keys.txt

# Ключи Reality
reality_private.key
reality_public.key

# -----------------------------------------------------------------------------
# DOCKER И КОНТЕЙНЕРЫ
# -----------------------------------------------------------------------------
# Docker файлы
docker-compose.override.yml
docker-compose.local.yml

# Временные файлы контейнеров
*.dockerignore
Dockerfile.local

# -----------------------------------------------------------------------------
# РАЗРАБОТКА И СБОРКА
# -----------------------------------------------------------------------------
# Файлы IDE
.vscode/
.idea/
*.iml
*.project
*.classpath
.settings/

# Файлы сборки
build/
dist/
out/
target/
*.exe
*.dll
*.so
*.dylib
*.o
*.obj

# Пакетные менеджеры
node_modules/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.coverage
*.egg-info/
venv/
.env/
Pipfile.lock
poetry.lock
yarn.lock
package-lock.json

# -----------------------------------------------------------------------------
# ОСОБЫЕ ФАЙЛЫ ПРОЕКТА
# -----------------------------------------------------------------------------
# Валидационный скрипт (можно перегенерировать)
validate.sh

# Архивы проекта
orchestra.7z

# Тестовые файлы и данные
test-data/
samples/
examples/

# -----------------------------------------------------------------------------
# НЕ ТРЕБУЕТСЯ ДЛЯ РАБОТЫ
# -----------------------------------------------------------------------------
# Документация в других форматах (оставляем только .md)
*.docx
*.pdf
*.pptx
*.xlsx

# Скриншоты и изображения (кроме README)
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.ico

# Аудио/видео файлы
*.mp3
*.mp4
*.avi
*.mov
*.wav